<%- include('./partials/header') %>

<% if(user.cart.length === 0){ %>

<!-- EMPTY CART UI -->

<div class="w-full h-[80vh] flex flex-col items-center justify-center text-center">

  <img src="https://cdn-icons-png.flaticon.com/512/2038/2038854.png"
       class="w-40 mb-6 opacity-80">

  <h2 class="text-2xl font-semibold mb-2">Your cart is empty 🛒</h2>

  <p class="text-gray-500 mb-6">
    Looks like you haven't added anything yet.
  </p>

  <a href="/shop"
     class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700">
     Continue Shopping
  </a>

</div>

<% } else { %>
<div class="w-full flex px-20 py-10 gap-10">

  <!-- LEFT SIDE: PRODUCTS -->
  <div class="w-[60%] flex flex-col gap-10">

    <% user.cart.forEach(function(item){ %>

    <div class="w-full flex gap-10">

      <!-- PRODUCT CARD -->
      <div class="w-[40%] rounded-md overflow-hidden shadow">

        <div class="w-full flex justify-center items-center h-60 bg-[<%= item.product.bgcolor%>]">
          <img class="h-[12rem]" src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>">
        </div>

        <div class="w-full flex justify-between px-5 py-4 bg-[<%=item.product.panelcolor %>]">
          <h3 class="text-lg font-semibold"><%= item.product.name %></h3>

          <div class="flex items-center gap-2">
            <a class="w-6 h-6 bg-white flex rounded-full items-center justify-center"
               href="/cart/decrease/<%= item.product._id %>">-</a>

            <div class="px-2 py-1 rounded-md bg-white text-black">
              <%= item.quantity %>
            </div>

            <a class="w-6 h-6 bg-white flex rounded-full items-center justify-center"
               href="/cart/increase/<%= item.product._id %>">+</a>
          </div>
        </div>

        <div class="flex text-white justify-between px-5 py-3 bg-[<%=item.product.textcolor %>]">
          <h4>Net Total</h4>
          <h2>₹<%= (item.product.price - item.product.discount) * item.quantity %></h2>
        </div>

      </div>

      
      <div class="w-[60%] flex flex-col justify-center">
     <p class="text-gray-600">
      <%= item.product.description %>
    </p>
      <div class="text-black-500">
      <% for(let i=1; i<=5; i++){ %>
      <% if(i <= item.product.rating){ %>
      ⭐
      <% } else { %>
      ☆
     <% } %>
    <% } %>
      </div>

    <div>
      <% if(item.product.stock > 0){ %>
        <span class="text-green-600">In Stock</span>
      <% } else { %>
        <span class="text-red-600">Out of Stock</span>
      <% } %>
    </div>


        <p><b>Price:</b> ₹<%= item.product.price %></p>
        <p><b>Discount:</b> ₹<%= item.product.discount %></p>
        <p><b>Quantity:</b> <%= item.quantity %></p>

        
        <a href="/cart/remove/<%= item.product._id %>"
           onclick="return confirm('Remove this item?')"
           class="text-red-500 mt-3 hover:underline">
           Remove Item
        </a>

      </div>

    </div>

    <% }) %> 

  </div>

  <!-- RIGHT SIDE: SINGLE PRICE SUMMARY -->
  <div class="w-[40%] bg-white p-6 rounded-lg shadow h-fit">

    <h2 class="text-xl font-semibold mb-5">Price Summary</h2>

    <div class="flex justify-between mb-3">
      <span>Total Items</span>
      <span><%= user.cart.length %></span>
    </div>

    <div class="flex justify-between mb-3">
      <span>Subtotal</span>
      <span>₹<%= bill - 20 %></span>
    </div>

    <div class="flex justify-between mb-3">
      <span>Platform Fee</span>
      <span>₹20</span>
    </div>

    <div class="flex justify-between mb-3">
      <span>Shipping</span>
      <span>FREE</span>
    </div>

    <hr class="my-4">

    <div class="flex justify-between text-lg font-bold text-green-600">
      <span>Total Amount</span>
      <span>₹<%= bill %></span>
    </div>
    
    <div class="mt-6">
      <a href="/checkout"
         class="block w-full text-center bg-green-600 text-white py-3 rounded-lg font-semibold hover:bg-green-700">
         Place Order
      </a>
    </div>

  </div>

</div>
 <% } %>
<%- include('./partials/footer') %>