<%- include('./partials/header') %>

<div class="w-[85%] mx-auto mt-10 flex gap-6">

  <!-- LEFT MAIN -->
  <div class="w-[70%] bg-white p-6 rounded-lg shadow">

    <!-- PRODUCT LIST -->
  <% let totalMRP = 0; %>
<% let totalDiscount = 0; %>

<% order.products.forEach(item => { %>

  <% 
    let price = item.productId.price;
    let discount = item.productId.discount || 0;
    let finalPrice = price - discount;
    let itemTotal = finalPrice * item.quantity;

    totalMRP += price * item.quantity;
    totalDiscount += discount * item.quantity;
  %>

  <div class="flex justify-between items-center border-b pb-4 mb-4">

    <div class="flex gap-4">

      <img class="w-20 h-20 object-contain"
        src="data:image/jpeg;base64,<%= item.productId.image.toString('base64') %>">

      <div>
        <p class="font-medium"><%= item.productId.name %></p>
        <p class="text-sm text-gray-500">Qty: <%= item.quantity %></p>
      </div>

    </div>

    <div class="font-semibold text-gray-800">
      ₹ <%= itemTotal %>
    </div>

  </div>

<% }) %>

    <!-- 🚀 TIMELINE -->
    <div class="mt-8">

  <p class="font-semibold mb-5 text-lg">Order Status</p>

  <div class="relative pl-6">

    <% const steps = ["Pending", "Shipped", "Out for Delivery", "Delivered"]; %>

    <% steps.forEach((step, index) => { %>

      <div class="flex items-start gap-4 mb-6 relative">

        <!-- LINE -->
        <% if(index !== steps.length - 1){ %>
          <div class="absolute left-[6px] top-5 w-[2px] h-full 
            <%= steps.indexOf(order.status) > index ? 'bg-green-500' : 'bg-gray-300' %>">
          </div>
        <% } %>

        <!-- CIRCLE -->
        <div class="
  w-6 h-6 flex items-center justify-center rounded-full text-white text-xs
  <%= steps.indexOf(order.status) >= index 
      ? 'bg-green-500' 
      : 'bg-gray-300' %>
">
  <% if(step === "Pending"){ %>🧾<% } %>
  <% if(step === "Shipped"){ %>🚚<% } %>
  <% if(step === "Out for Delivery"){ %>📦<% } %>
  <% if(step === "Delivered"){ %>✅<% } %>
</div>

        <!-- TEXT -->
        <div>
          <p class="
            font-medium
            <%= steps.indexOf(order.status) >= index 
                ? 'text-gray-800' 
                : 'text-gray-400' %>
          ">
            <%= step %>
          </p>

          <!-- OPTIONAL DATE -->
          <% if(steps.indexOf(order.status) >= index){ %>
            <p class="text-xs text-gray-500">
              <%= new Date(order.date).toLocaleDateString() %>
            </p>
          <% } %>

        </div>

      </div>

    <% }) %>

  </div>

</div>
   

  </div>

  <!-- RIGHT PANEL -->
  <div class="w-[30%] space-y-4">

    <!-- ADDRESS -->
    <div class="bg-white p-4 rounded-lg shadow">
      <p class="font-semibold mb-2">Delivery Details</p>
      <p class="font-medium"><%= order.address.name %></p>
      <p class="text-sm text-gray-600">
        <%= order.address.location %> - <%= order.address.pincode %>
      </p>
      <p class="mt-1">📞 <%= order.address.phoneno %></p>
    </div>

    <!-- PRICE DETAILS -->
    <div class="bg-white p-5 rounded-lg shadow">

      <p class="font-semibold mb-4 text-lg">Price Details</p>

      <div class="space-y-2 text-sm">

        <div class="flex justify-between">
          <span>Listing price</span>
          <span class="line-through text-green-600">₹ <%= totalMRP %></span>
        </div>

        <div class="flex justify-between">
          <span>Discount</span>
          <span class="text-green-600">- ₹ <%= totalDiscount %></span>
        </div>

        <div class="flex justify-between">
          <span>Delivery Charges</span>
          <span class="text-green-600">FREE</span>
        </div>
        <div class="flex justify-between">
          <span>Platform Fee</span>
          <span class="text-green-600">+ ₹20</span>
        </div>


        <hr class="my-3">

        <div class="flex justify-between font-semibold text-lg">
          <span>Total Amount</span>
          <span>₹ <%= order.total%></span>
        </div>

      </div>

      <!-- PAYMENT -->
      <div class="mt-4 border-t pt-3 text-sm">
        <p class="text-gray-500">Payment Method</p>
        <p class="font-medium">Online Payment</p>
      </div>

      <!-- INVOICE BUTTON -->
      <button class="w-full mt-4 border rounded-lg py-2 hover:bg-gray-100 transition">
        📄 Download Invoice
      </button>

    </div>

  </div>

</div>

<%- include('./partials/footer') %>