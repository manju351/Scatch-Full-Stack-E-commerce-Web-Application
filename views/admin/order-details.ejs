<%- include('../partials/admin-header') %>

<div class="w-[85%] mx-auto mt-10 flex gap-6">

  <!-- LEFT SIDE -->
  <div class="w-[65%] bg-white p-6 rounded-xl shadow">

    <!-- ORDER HEADER -->
    <h2 class="text-xl font-semibold mb-4">
      Order ID: <%= order.orderId %>
    </h2>

    <p class="text-sm text-gray-500 mb-6">
      Placed on <%= new Date(order.orderDate || order.createdAt).toDateString() %>
    </p>

    <!-- PRODUCTS -->
        <% order.products.forEach(item => { %>

  <% 
    let price = item.productId.price;
    let discount = item.productId.discount || 0;
    let finalPrice = price - discount;
    let itemTotal = finalPrice * item.quantity;
  %>

  <div class="flex justify-between items-center border-b pb-4 mb-4">

    <div class="flex gap-4 items-center">

      <% if(item.productId && item.productId.image){ %>
        <img class="w-20 h-20 object-contain border rounded"
          src="data:image/jpeg;base64,<%= item.productId.image.toString('base64') %>">
      <% } %>

      <div>
        <p class="font-medium">
          <%= item.productId?.name || "Product" %>
        </p>

        <p class="text-sm text-gray-500">
          Qty: <%= item.quantity %>
        </p>

        <div class="text-sm mt-1">
          <span class="line-through text-gray-400">₹<%= price %></span>
          <span class="text-green-600 ml-2">₹<%= finalPrice %></span>
        </div>
      </div>

    </div>

    <div class="font-semibold text-gray-800">
      ₹ <%= itemTotal %>
    </div>

  </div>

<% }) %>

    <!-- STATUS UPDATE (READ ONLY FOR USER) -->
        <div class="mt-6">

  <p class="font-semibold mb-2">Update Order Status</p>

  <form action="/admin/orders/update-status/<%= order.orderId %>" method="POST" class="flex gap-3">

    <select name="status" class="border p-2 rounded">

      <option <%= order.status==="Pending"?"selected":"" %>>Pending</option>
      <option <%= order.status==="Shipped"?"selected":"" %>>Shipped</option>
      <option <%= order.status==="Out for Delivery"?"selected":"" %>>Out for Delivery</option>
      <option <%= order.status==="Delivered"?"selected":"" %>>Delivered</option>
      <option <%= order.status==="Cancelled"?"selected":"" %>>Cancelled</option>

    </select>

    <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
      Update
    </button>

  </form>

</div>

    <!-- TIMELINE -->
    <div class="mt-8">

      <p class="font-semibold mb-4">Order Timeline</p>

      <div class="border-l-2 pl-4 space-y-4">

        <% if(order.timeline && order.timeline.length > 0){ %>

          <% order.timeline.forEach(step => { %>

            <div>
              <p class="font-medium"><%= step.status %></p>
              <p class="text-sm text-gray-500">
                <%= new Date(step.date).toLocaleString() %>
              </p>
            </div>

          <% }) %>

        <% } else { %>

          <p class="text-sm text-gray-500">No updates yet</p>

        <% } %>

      </div>

    </div>

  </div>

  <!-- RIGHT SIDE -->
  <div class="w-[35%] space-y-4">

    <!-- CUSTOMER DETAILS -->
    <div class="bg-white p-4 rounded-xl shadow">

      <p class="font-semibold mb-2">Delivery Details</p>

      <p class="font-medium"><%= order.address?.name || "" %></p>

      <p class="text-sm text-gray-600 mt-1">
        <%= order.address?.location || "" %> - <%= order.address?.pincode || "" %>
      </p>

      <p class="text-sm mt-1">
        📞 <%= order.address?.phoneno || "" %>
      </p>

    </div>

    <!-- PRICE DETAILS -->
    <div class="bg-white p-4 rounded-xl shadow">

      <p class="font-semibold mb-3">Price Details</p>

      <div class="flex justify-between text-sm mb-2">
        <span>Total Amount</span>
        <span class="font-semibold text-green-600">
          ₹ <%= order.total %>
        </span>
      </div>

      <div class="text-sm text-gray-500 mt-2">
        Payment Method: Online
      </div>

    </div>

  </div>

</div>

<%- include('../partials/admin-footer') %>