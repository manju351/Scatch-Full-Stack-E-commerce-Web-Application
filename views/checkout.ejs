<%- include('./partials/header') %>

<div class="w-full flex justify-center mt-10">

  <div class="w-[85%] flex gap-10">

    <!-- ✅ LEFT: PRODUCT LIST -->
    <div class="w-[60%]">

      <h2 class="text-xl font-semibold mb-5">Order Items</h2>

      <% user.cart.forEach(function(item){ %>

      <div class="flex items-center gap-5 mb-5 border-b pb-4">

        <img class="h-20"
             src="data:image/jpeg;base64,<%= item.product.image.toString('base64') %>">

        <div class="flex flex-col">
          <h3 class="font-medium"><%= item.product.name %></h3>
          <p>₹ <%= item.product.price %></p>
          <p>Qty: <%= item.quantity %></p>
        </div>

        <div class="ml-auto font-semibold">
          ₹ <%= (item.product.price - item.product.discount) * item.quantity %>
        </div>

      </div>

      <% }) %>

    </div>

    <!-- ✅ RIGHT: SUMMARY + ADDRESS -->
    <div class="w-[40%] bg-white p-6 rounded-lg shadow h-fit">

      <h2 class="text-xl font-semibold mb-5">Checkout</h2>

      <!-- TOTAL -->
      <div class="flex justify-between mb-2">
        <span>Total Items</span>
        <span><%= totalItems %></span>
      </div>

      <div class="flex justify-between mb-2">
        <span>Subtotal</span>
        <span>₹ <%= bill - 20 %></span>
      </div>

      <div class="flex justify-between mb-2">
        <span>Platform Fee</span>
        <span>₹ 20</span>
      </div>

      <hr class="my-3">

      <div class="flex justify-between font-bold text-green-600 mb-5">
        <span>Total</span>
        <span>₹ <%= bill %></span>
      </div>

      <!-- ✅ ADDRESS FORM -->
      <form action="/place-order" method="POST" class="flex flex-col gap-3">

        <input type="text" name="name" placeholder="Full Name"
               class="border px-3 py-2 rounded" required>

        <input type="text" name="phone" placeholder="Phone Number"
               class="border px-3 py-2 rounded" required>

        <textarea name="address" placeholder="Address"
                  class="border px-3 py-2 rounded" required></textarea>

        <input type="text" name="pincode" placeholder="Pincode"
               class="border px-3 py-2 rounded" required>

        <!-- PLACE ORDER -->
        <button type="submit"
                class="bg-green-600 text-white py-3 rounded-lg mt-3 hover:bg-green-700">
          Continue to Payment
        </button>

      </form>

    </div>

  </div>

</div>

<%- include('./partials/footer') %>